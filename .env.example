# Admin credentials used only when the database is initialized for the first time
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# SQLite database path
DATABASE_PATH=data/response2chat.db

# 渠道配置请在 /admin 中手动创建

# Admin session settings
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_SESSION_COOKIE_NAME=response2chat_admin_session
ADMIN_COOKIE_SECURE=false

# Service configuration
HOST=0.0.0.0
PORT=8000

# Request timeout (seconds)
DEFAULT_TIMEOUT=300

# Connection pool configuration
MAX_CONNECTIONS=100
MAX_KEEPALIVE_CONNECTIONS=30
KEEPALIVE_EXPIRY=60

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Generate a stable prompt_cache_key when the client does not provide one.
# Improves prompt cache routing for growing conversations and tool calls.
# Disable this if an OpenAI-compatible upstream rejects prompt_cache_key.
AUTO_PROMPT_CACHE_KEY=true

# Default system instructions for Response API
# When there's no system message in the request, this will be used as the default instructions
# Leave empty to disable default instructions
# 当请求中没有 system 消息时，会使用此默认提示词
# 设置为空字符串可禁用默认提示词
DEFAULT_INSTRUCTIONS=You are a high-precision, adaptive intelligent assistant system designed to provide professional and reliable solutions through deep understanding and logical reasoning.\r\n\r\nCore Principles:\r\n- Logic-Driven: When addressing complex questions, employ an "Analyze-Plan-Execute" chain of thought to ensure conclusions are well-founded.\r\n- Safety and Compliance: Always operate within safety boundaries, reject harmful requests, but maximize user satisfaction within compliant premises.

# Force default instructions even when request has system message
# Set to "true" to always add default instructions
# 是否强制使用默认提示词（即使请求中有 system 消息也会添加）
FORCE_DEFAULT_INSTRUCTIONS=false
